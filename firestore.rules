rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          "voltaravn@gmail.com",
          "voltaravietnam@gmail.com",
          "tuanmanhbh@gmail.com"
        ];
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /academyCourses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /newsletterSubscribers/{email} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    match /contactSubmissions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /quoteRequests/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /warranties/{warrantyId} {
      allow read: if true;
      allow create: if isAdmin()
        || (
          !exists(/databases/$(database)/documents/warranties/$(warrantyId))
          && request.resource.data.status == "Chờ admin duyệt"
          && request.resource.data.activationSource == "customer"
        );
      allow update, delete: if isAdmin();
    }

    match /dealerAccounts/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create, update, delete: if isAdmin();
    }

    match /dealerOrders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.dealerUid == request.auth.uid
        && get(/databases/$(database)/documents/dealerAccounts/$(request.auth.uid)).data.status == "active";
      allow read: if isAdmin() || (isSignedIn() && resource.data.dealerUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /landingPages/{pageId} {
      allow read: if isAdmin() || resource.data.status == "published";
      allow create, update, delete: if isAdmin();
    }

    match /landingOrders/{orderId} {
      // Task 8 will write through a trusted Next.js API using Firebase Admin SDK.
      allow create: if false;
      allow read, update, delete: if isAdmin();
    }

    match /landingOrderDedup/{dedupeId} {
      // Internal idempotency pointers are only written by Firebase Admin SDK.
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
